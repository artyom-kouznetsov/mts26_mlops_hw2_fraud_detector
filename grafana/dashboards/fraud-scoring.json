          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH recent AS (\n  SELECT cat_id, fraud_flag\n  FROM transaction_scores\n  WHERE us_state IN (${us_state:sqlstring})\n    AND merch IN (${merch:sqlstring})\n  ORDER BY processed_at DESC\n  LIMIT 1000\n)\nSELECT COALESCE(cat_id, 'unknown') AS category, AVG(fraud_flag::double precision) AS fraud_share\nFROM recent\nGROUP BY cat_id\nORDER BY fraud_share DESC, category",
