          "datasource": {"type": "grafana-postgresql-datasource", "uid": "fraud-postgres"},
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH buckets AS (\n  SELECT width_bucket(score, 0.0, 1.000001, 20) AS bucket\n  FROM transaction_scores\n  WHERE $__timeFilter(processed_at)\n    AND us_state IN (${us_state:sqlstring})\n    AND merch IN (${merch:sqlstring})\n), distribution AS (\n  SELECT bucket, COUNT(*)::double precision / NULLIF(SUM(COUNT(*)) OVER (), 0) AS value\n  FROM buckets\n  GROUP BY bucket\n)\nSELECT ROUND(((bucket - 0.5) / 20.0)::numeric, 3)::text AS score_bucket, value AS share\nFROM distribution\nORDER BY bucket",
          "refId": "A"
        }
      ],
      "title": "Score distribution",
      "type": "barchart"
    },
